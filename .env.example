# ── App ────────────────────────────────────────────────────────
APP_NAME=SATYA API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# ── AWS ────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_PROFILE=satya-dev

# ── S3 (filled after cdk deploy) ───────────────────────────────
MEDIA_BUCKET_NAME=satya-media-755483013810-ap-south-1

# ── DynamoDB ───────────────────────────────────────────────────
ANALYSES_TABLE_NAME=satya-analyses
TRENDING_TABLE_NAME=satya-trending

# ── SQS (filled after cdk deploy) ──────────────────────────────
VIDEO_QUEUE_URL=
AUDIO_QUEUE_URL=
TEXT_QUEUE_URL=

# ── YouTube Data API v3 ────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Amazon Bedrock ─────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
